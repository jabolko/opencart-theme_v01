{# ── Category bottom sheet (opened by #categories-open) ── #}
{# ── Filter bottom sheet (opened by #filter-open) ── #}

{# Shared overlay #}
<div class="filter-overlay" id="js-filter-overlay"></div>

{# ====== CATEGORY SHEET ====== #}
<div class="filter-sheet" id="js-cat-sheet" aria-hidden="true">
  <div class="filter-sheet__handle"><div class="filter-sheet__handle-bar"></div></div>
  <div class="filter-sheet__header">
    <span class="filter-sheet__title">Kategorije</span>
    <button class="filter-sheet__close js-sheet-close" type="button" aria-label="Zapri kategorije">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <div class="filter-sheet__body">
    <div class="filter-section__list" id="js-cat-list"></div>
  </div>
</div>

{# ====== FILTER SHEET ====== #}
{% if filter_groups %}
<div class="filter-sheet" id="js-filter-sheet" aria-hidden="true">
  <div class="filter-sheet__handle"><div class="filter-sheet__handle-bar"></div></div>
  <div class="filter-sheet__header">
    <span class="filter-sheet__title">Filtri</span>
    <button class="filter-sheet__close js-sheet-close" type="button" aria-label="Zapri filtre">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="filter-sheet__body">
    {# Active filter chips (populated by JS) #}
    <div class="active-filters" id="js-active-filters" style="display:none"></div>

    {# OC filter groups (e.g. Starost / Velikost) #}
    {% for filter_group in filter_groups %}
    <div class="filter-section">
      <div class="filter-section__header" onclick="this.parentElement.classList.toggle('is-collapsed')">
        <h3>{{ filter_group.name }}</h3>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
      <div class="filter-section__body">
        <div class="filter-section__list">
          {% for filter in filter_group.filter %}
          <label class="filter-item">
            {% if filter.filter_id in filter_category %}
            <input type="checkbox" class="filter-item__checkbox" name="filter[]" value="{{ filter.filter_id }}" checked="checked" />
            {% else %}
            <input type="checkbox" class="filter-item__checkbox" name="filter[]" value="{{ filter.filter_id }}" />
            {% endif %}
            <span class="filter-item__label">{{ filter.name }}</span>
          </label>
          {% endfor %}
        </div>
      </div>
    </div>
    {% endfor %}

    {# Manufacturer / brand section (populated by JS from page data) #}
    <div class="filter-section" id="js-filter-manufacturers" style="display:none">
      <div class="filter-section__header" onclick="this.parentElement.classList.toggle('is-collapsed')">
        <h3>Znamke</h3>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
      <div class="filter-section__body">
        <div class="filter-section__list" id="js-filter-manufacturers-list"></div>
      </div>
    </div>
  </div>

  {# Footer #}
  <div class="filter-sheet__footer">
    <button type="button" class="filter-sheet__reset" id="js-filter-reset">Ponastavi</button>
    <button type="button" class="filter-sheet__apply" id="js-filter-apply">Pokaži rezultate</button>
  </div>
</div>
{% endif %}

<script type="text/javascript"><!--
(function() {
  var overlay    = document.getElementById('js-filter-overlay');
  var catSheet   = document.getElementById('js-cat-sheet');
  var filterSheet = document.getElementById('js-filter-sheet');
  var catOpenBtn = document.getElementById('categories-open');
  var filterOpenBtn = document.getElementById('filter-open');
  var applyBtn   = document.getElementById('js-filter-apply');
  var resetBtn   = document.getElementById('js-filter-reset');
  var activeSheet = null;

  function openSheet(sheet) {
    if (!sheet) return;
    activeSheet = sheet;
    sheet.classList.add('filter-sheet--open');
    sheet.setAttribute('aria-hidden', 'false');
    overlay.classList.add('filter-overlay--visible');
    document.body.classList.add('filter-open');
  }

  function closeSheet() {
    if (activeSheet) {
      activeSheet.classList.remove('filter-sheet--open');
      activeSheet.setAttribute('aria-hidden', 'true');
      activeSheet = null;
    }
    overlay.classList.remove('filter-overlay--visible');
    document.body.classList.remove('filter-open');
  }

  // Close buttons (shared class)
  var closeBtns = document.querySelectorAll('.js-sheet-close');
  for (var i = 0; i < closeBtns.length; i++) {
    closeBtns[i].addEventListener('click', closeSheet);
  }
  if (overlay) { overlay.addEventListener('click', closeSheet); }

  document.addEventListener('keydown', function(e) {
    if ((e.key === 'Escape' || e.keyCode === 27) && activeSheet) { closeSheet(); }
  });

  // ── CATEGORY SHEET: populate from controller JSON (3-level tree) ──
  var catList   = document.getElementById('js-cat-list');
  var treeDataEl = document.getElementById('js-category-tree');

  if (catList && treeDataEl) {
    try {
      var tree = JSON.parse(treeDataEl.textContent);
      for (var i = 0; i < tree.length; i++) {
        var top = tree[i];
        var hasChildren = top.children && top.children.length > 0;
        var isInTree = top.current_parent; // we are somewhere inside this parent's tree

        // Level 1: top parent row (link + expand chevron)
        var row = document.createElement('div');
        row.className = 'cat-tree-row';

        var a = document.createElement('a');
        a.href = top.href;
        // Mark active if current category OR if we are inside this parent's tree
        a.className = 'filter-item filter-item--link' + ((top.active || isInTree) ? ' filter-item--active' : '');
        a.textContent = top.name;
        row.appendChild(a);

        if (hasChildren) {
          var chevron = document.createElement('button');
          chevron.type = 'button';
          chevron.className = 'cat-tree-toggle' + (isInTree ? ' cat-tree-toggle--open' : '');
          chevron.setAttribute('aria-label', 'Razširi ' + top.name);
          chevron.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#565656" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>';
          row.appendChild(chevron);
        }

        catList.appendChild(row);

        // Level 2: children container (collapsible)
        if (hasChildren) {
          var childWrap = document.createElement('div');
          childWrap.className = 'cat-tree-children' + (isInTree ? '' : ' cat-tree-children--hidden');

          for (var j = 0; j < top.children.length; j++) {
            var l2 = top.children[j];
            var l2a = document.createElement('a');
            l2a.href = l2.href;
            l2a.className = 'filter-item filter-item--link filter-item--sub' + (l2.active ? ' filter-item--active' : '');
            l2a.textContent = l2.name;
            childWrap.appendChild(l2a);

            // Level 3: children under active level-2
            if (l2.current_parent && l2.children) {
              for (var k = 0; k < l2.children.length; k++) {
                var l3 = l2.children[k];
                var l3a = document.createElement('a');
                l3a.href = l3.href;
                l3a.className = 'filter-item filter-item--link filter-item--sub-2' + (l3.active ? ' filter-item--active' : '');
                l3a.textContent = l3.name;
                childWrap.appendChild(l3a);
              }
            }
          }

          catList.appendChild(childWrap);

          // Toggle expand/collapse on chevron click
          (function(btn, wrap) {
            btn.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopPropagation();
              var isOpen = !wrap.classList.contains('cat-tree-children--hidden');
              if (isOpen) {
                wrap.classList.add('cat-tree-children--hidden');
                btn.classList.remove('cat-tree-toggle--open');
              } else {
                wrap.classList.remove('cat-tree-children--hidden');
                btn.classList.add('cat-tree-toggle--open');
              }
            });
          })(chevron, childWrap);
        }
      }
    } catch(e) {}
  }

  if (catOpenBtn) {
    catOpenBtn.addEventListener('click', function() { openSheet(catSheet); });
  }

  // ── FILTER SHEET: manufacturers ──
  var mfrSection = document.getElementById('js-filter-manufacturers');
  var mfrList    = document.getElementById('js-filter-manufacturers-list');
  var mfrDataEl  = document.getElementById('js-manufacturer-data');

  if (mfrList && mfrDataEl) {
    try {
      var manufacturers = JSON.parse(mfrDataEl.textContent);
      if (manufacturers.length > 0) {
        mfrSection.style.display = '';
        for (var m = 0; m < manufacturers.length; m++) {
          var mfr = manufacturers[m];
          var label = document.createElement('label');
          label.className = 'filter-item';

          var cb = document.createElement('input');
          cb.type = 'checkbox';
          cb.className = 'filter-item__checkbox';
          cb.name = 'manufacturer[]';
          cb.value = mfr.manufacturer_id;
          if (mfr.selected) { cb.checked = true; }

          var span = document.createElement('span');
          span.className = 'filter-item__label';
          span.textContent = mfr.name;

          label.appendChild(cb);
          label.appendChild(span);
          mfrList.appendChild(label);
        }
      }
    } catch(e) {}
  }

  // ── FILTER SHEET: active filter chips ──
  var chipsEl    = document.getElementById('js-active-filters');
  var activeDataEl = document.getElementById('js-active-filters-data');

  if (chipsEl && activeDataEl && filterSheet) {
    try {
      var activeFilters = JSON.parse(activeDataEl.textContent);
      if (activeFilters.length > 0) {
        chipsEl.style.display = '';
        for (var c = 0; c < activeFilters.length; c++) {
          (function(af) {
            var chip = document.createElement('button');
            chip.type = 'button';
            chip.className = 'active-filters__chip';
            chip.innerHTML = af.name + ' <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
            chip.addEventListener('click', function() {
              var selector = af.type === 'manufacturer'
                ? 'input[name="manufacturer[]"]'
                : 'input[name="filter[]"]';
              var boxes = filterSheet.querySelectorAll(selector);
              for (var b = 0; b < boxes.length; b++) {
                var lbl = boxes[b].parentElement.querySelector('.filter-item__label');
                if (lbl && lbl.textContent.trim() === af.name) {
                  boxes[b].checked = false;
                }
              }
              chip.remove();
              if (!chipsEl.querySelector('.active-filters__chip')) {
                chipsEl.style.display = 'none';
              }
            });
            chipsEl.appendChild(chip);
          })(activeFilters[c]);
        }
        var clearLink = document.createElement('button');
        clearLink.type = 'button';
        clearLink.className = 'active-filters__clear';
        clearLink.textContent = 'Počisti vse';
        clearLink.addEventListener('click', function() {
          var allChecked = filterSheet.querySelectorAll('input[name="filter[]"], input[name="manufacturer[]"]');
          for (var x = 0; x < allChecked.length; x++) { allChecked[x].checked = false; }
          chipsEl.style.display = 'none';
          chipsEl.innerHTML = '';
        });
        chipsEl.appendChild(clearLink);
      }
    } catch(e) {}
  }

  if (filterOpenBtn) {
    filterOpenBtn.addEventListener('click', function() { openSheet(filterSheet); });
  }

  // ── Apply / Reset ──
  if (applyBtn) {
    applyBtn.addEventListener('click', function() {
      var url = '{{ action|escape('js') }}';

      var checkedFilters = filterSheet.querySelectorAll('input[name="filter[]"]:checked');
      var filterIds = [];
      for (var i = 0; i < checkedFilters.length; i++) { filterIds.push(checkedFilters[i].value); }
      if (filterIds.length > 0) { url += '&filter=' + filterIds.join(','); }

      var checkedMfrs = filterSheet.querySelectorAll('input[name="manufacturer[]"]:checked');
      var mfrIds = [];
      for (var i = 0; i < checkedMfrs.length; i++) { mfrIds.push(checkedMfrs[i].value); }
      if (mfrIds.length > 0) { url += '&filter_manufacturer=' + mfrIds.join(','); }

      location = url;
    });
  }

  if (resetBtn) {
    resetBtn.addEventListener('click', function() { location = '{{ action|escape('js') }}'; });
  }
})();
//--></script>
