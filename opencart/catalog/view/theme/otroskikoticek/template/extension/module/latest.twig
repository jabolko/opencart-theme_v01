<div class="product-grid">
  {% for product in products %}
  <article class="product-card">

    <div class="product-card__media">
      <a href="{{ product.href }}" class="product-card__img-wrap">
        <div class="product-card__img">
          <div class="product-card__labels">
            {% if product.reservation_status == 'in_cart' %}
              <span class="product-label product-label--in-cart">V KOŠARICI</span>
            {% elseif product.reservation_status == 'reserved' %}
              <span class="product-label product-label--reserved">REZERVIRANO</span>
            {% elseif product.reservation_status == 'sold' %}
              <span class="product-label product-label--sold">PRODANO</span>
            {% else %}
              {% if product.is_new %}<span class="product-label product-label--novo">NOVO</span>{% endif %}
              {% if product.is_top_brand %}<span class="product-label product-label--brand">Top znamka</span>{% endif %}
              {% if product.has_tag_label %}<span class="product-label product-label--tagged">Z etiketo</span>{% endif %}
            {% endif %}
          </div>
          <img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy">
        </div>
      </a>
      <button class="product-card__fav"
              type="button"
              onclick="wishlist.add('{{ product.product_id }}');"
              aria-label="{{ button_wishlist }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </button>
    </div>

    <div class="product-card__body">
      {% if product.manufacturer %}
      <p class="product-card__manufacturer">{{ product.manufacturer }}</p>
      {% endif %}
      <a href="{{ product.href }}" class="product-card__name">{{ product.name }}</a>
      <div class="product-card__footer">
        {% if product.price %}
        <p class="product-card__price">
          {% if product.special %}
            <span class="product-card__price-new">{{ product.special }}</span>
            <span class="product-card__price-old">{{ product.price }}</span>
          {% else %}
            {{ product.price }}
          {% endif %}
        </p>
        {% endif %}
        {% if product.in_cart %}
        <button class="product-card__cart product-card__cart--in-cart" type="button" disabled aria-label="V košarici">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
        {% elseif product.reservation_status == 'reserved' or product.reservation_status == 'sold' %}
        <button class="product-card__cart product-card__cart--disabled" type="button" disabled aria-label="Ni na voljo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
          </svg>
        </button>
        {% else %}
        <button class="product-card__cart" type="button" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum }}');" aria-label="{{ button_cart }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
          </svg>
        </button>
        {% endif %}
      </div>
    </div>

  </article>
  {% endfor %}
</div>
