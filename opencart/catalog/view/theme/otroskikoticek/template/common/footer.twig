        <p class="site-footer__col-title site-footer__col-title--spaced site-footer__col-title--toggle"
           role="button" tabindex="0" aria-expanded="false">
          Moj račun
          <svg class="site-footer__col-arrow" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
