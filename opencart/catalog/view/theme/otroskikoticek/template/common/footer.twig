        <ul class="site-footer__links">
          <li><a href="{{ account }}">Moj račun</a></li>
          <li><a href="{{ order }}">Moje naročilo</a></li>
          <li><a href="{{ wishlist }}">Seznam želja</a></li>
        </ul>
      </div>

      {# Col 4: Newsletter #}
      <div class="site-footer__newsletter">
        <p class="site-footer__nl-title">Ostanite obveščeni</p>
        <p class="site-footer__nl-heading">Bodite prvi, ki izveste za nove kose</p>
        <p class="site-footer__nl-desc">Prijavite se in izveste takoj, ko prispejo novi kosi vaših najljubših znamk.</p>
        <form class="site-footer__nl-form" method="post" action="{{ base }}index.php?route=account/newsletter">
          <input type="email" class="site-footer__nl-input" name="email" placeholder="Vaš e-poštni naslov" required>
          <button type="submit" class="site-footer__nl-btn">Prijavi se na novice</button>
        </form>
        <p class="site-footer__nl-privacy">S prijavo se strinjate s prejemanjem obvestil. Odjava je mogoča kadarkoli.</p>
      </div>

    </div>
