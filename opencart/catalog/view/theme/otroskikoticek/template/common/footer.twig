          <li><a href="{{ sitemap }}">Zemljevid strani</a></li>
          <li><a href="{{ voucher }}">Darilni bon</a></li>
          <li><a href="#">Dostava</a></li>
          <li><a href="#">Pomoč pri nakupu</a></li>
        </ul>
      </div>

      {# Col 3: Odkrijte + Moj račun #}
