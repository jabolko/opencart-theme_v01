    <div class="container">
      <div class="site-footer__proof-inner">

        <div class="site-footer__quote">
          <img class="site-footer__avatar"
               src="{{ base }}image/catalog/assets/elements/spletna-meta-002.jpg"
               alt="Meta, ustanoviteljica Otroškega kotička"
               width="107" height="107">
          <p class="site-footer__quote-text">
            &#8220;Otroški kotiček &#8211; nežno rabljena otroška oblačila,<br class="site-footer__quote-break">
            izbrana z ljubeznijo in mislijo na vašo družino.&#8221;<br class="site-footer__quote-break">
            &#8212; <strong>Meta</strong>
          </p>
        </div>

        <a href="https://www.google.com/maps?cid=10577519604965280683"
           class="site-footer__google"
           target="_blank" rel="noopener"
