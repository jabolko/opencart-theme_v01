        <ul class="site-footer__links">
          <li><a href="{{ base }}index.php?route=information/information&information_id=9">Prodaj oblačila</a></li>
          <li><a href="{{ base }}index.php?route=information/information&information_id=11">Mnenja strank</a></li>
          <li><a href="#">O nas</a></li>
          <li><a href="{{ contact }}">Kontakt</a></li>
