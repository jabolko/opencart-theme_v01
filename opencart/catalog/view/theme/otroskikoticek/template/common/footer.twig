        <address class="site-footer__address">Šolska ulica 2<br>3330 Mozirje</address>
        <div class="site-footer__hours">
          <span class="site-footer__hours-day">Tor &#8211; Pet</span><span class="site-footer__hours-time">10:00 &#8211; 18:00</span>
          <span class="site-footer__hours-day">Sobota</span><span class="site-footer__hours-time">9:00 &#8211; 12:00</span>
          <span class="site-footer__hours-day site-footer__hours--closed">Pon, Ned</span><span class="site-footer__hours-time site-footer__hours--closed">Zaprto</span>
        </div>
        <a href="tel:+38640611233" class="site-footer__contact">
          <svg aria-hidden="true"><use href="#ft-phone"/></svg>
          +386 40 611 233
        </a>
        <a href="{{ contact }}" class="site-footer__contact">
          <svg aria-hidden="true"><use href="#ft-mail"/></svg>
          info@otroski-koticek.si
        </a>
        <div class="site-footer__socials">
          <a href="https://www.facebook.com/otroskikoticek/" class="site-footer__social" target="_blank" rel="noopener" aria-label="Facebook">
            <svg aria-hidden="true"><use href="#ft-fb"/></svg>
          </a>
          <a href="https://www.instagram.com/otroski_koticek" class="site-footer__social" target="_blank" rel="noopener" aria-label="Instagram">
