<!-- otroskikoticek theme active -->
<!DOCTYPE html>
<!--[if IE]><![endif]-->
<!--[if IE 8 ]><html dir="{{ direction }}" lang="{{ lang }}" class="ie8"><![endif]-->
<!--[if IE 9 ]><html dir="{{ direction }}" lang="{{ lang }}" class="ie9"><![endif]-->
<!--[if (gt IE 9)|!(IE)]><!-->
<html dir="{{ direction }}" lang="{{ lang }}">
<!--<![endif]-->
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ title }}</title>
<base href="{{ base }}" />
<link rel="preload" href="catalog/view/theme/otroskikoticek/stylesheet/dist/fonts/open-sans-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="catalog/view/theme/otroskikoticek/stylesheet/dist/fonts/dm-sans-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
{% if description %}
<meta name="description" content="{{ description }}" />
{% endif %}
{% if keywords %}
<meta name="keywords" content="{{ keywords }}" />
{% endif %}
<script src="catalog/view/javascript/jquery/jquery-3.7.1.min.js" type="text/javascript"></script>
<link href="catalog/view/javascript/bootstrap/css/bootstrap.min.css" rel="stylesheet" media="screen" />
<script src="catalog/view/javascript/bootstrap/js/bootstrap.min.js" type="text/javascript"></script>
<link href="catalog/view/javascript/font-awesome/css/font-awesome.min.css" rel="stylesheet" type="text/css" />
<link href="catalog/view/theme/otroskikoticek/stylesheet/dist/theme.min.css" rel="stylesheet" />
{% for style in styles %}
<link href="{{ style.href }}" type="text/css" rel="{{ style.rel }}" media="{{ style.media }}" />
{% endfor %}
{% for script in scripts %}
<script src="{{ script }}" type="text/javascript"></script>
{% endfor %}
<script src="catalog/view/javascript/common.js" type="text/javascript"></script>
{% for link in links %}
<link href="{{ link.href }}" rel="{{ link.rel }}" />
{% endfor %}
{% for analytic in analytics %}
{{ analytic }}
{% endfor %}
</head>
<body>
<div class="site-header">

  <header>
    <div class="container">
      <div class="header-inner">

        <!-- Mobile hamburger — CSS hides on desktop -->
        <button class="mobile-menu-toggle" id="js-mobile-menu-toggle"
                aria-label="Odpri meni" aria-expanded="false" aria-controls="js-mobile-nav">
          <span class="mobile-menu-toggle__bar"></span>
          <span class="mobile-menu-toggle__bar"></span>
          <span class="mobile-menu-toggle__bar"></span>
        </button>

        <!-- Logo -->
        <div class="header-logo">
          <div id="logo">
            <a href="{{ home }}">
              <picture>
                <source media="(max-width: 767px)" srcset="image/catalog/assets/logo/Logo-150x20px-invert.svg">
                <img src="image/catalog/assets/logo/Logo-250x32px-normal.svg" width="250" height="33" title="{{ name }}" alt="{{ name }}" />
              </picture>
            </a>
          </div>
        </div>

        <!-- Search -->
        <div class="header-search">{{ search }}</div>

        <!-- Header actions -->
        <div class="header-actions">

          <!-- Account dropdown -->
          <div class="header-action dropdown">
            <a href="{{ account }}" class="header-action__btn dropdown-toggle" data-toggle="dropdown" title="{{ text_account }}">
              <svg class="header-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </a>
            <ul class="dropdown-menu dropdown-menu-right">
              {% if logged %}
              <li><a href="{{ account }}">{{ text_account }}</a></li>
              <li><a href="{{ order }}">{{ text_order }}</a></li>
              <li><a href="{{ transaction }}">{{ text_transaction }}</a></li>
              <li><a href="{{ download }}">{{ text_download }}</a></li>
              <li><a href="{{ logout }}">{{ text_logout }}</a></li>
              {% else %}
              <li><a href="{{ register }}">{{ text_register }}</a></li>
              <li><a href="{{ login }}">{{ text_login }}</a></li>
              {% endif %}
            </ul>
          </div>

          <!-- Wishlist — span is updated by OC JS: $('#wishlist-total span').html(count) -->
          <a href="{{ wishlist }}" id="wishlist-total" class="header-action header-action__btn" title="{{ text_wishlist }}">
            <svg class="header-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            <span class="sr-only"></span>
          </a>

          <!-- Mobile search button — shown only on mobile, opens the main search field -->
          <button type="button" class="header-action__btn mobile-search-btn" id="js-mobile-search-btn" aria-label="Iskanje">
            <svg class="header-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </button>

          <!-- Cart widget (OC-provided dropdown) -->
          <div class="header-action header-action--cart">{{ cart }}</div>

        </div>
      </div>
    </div>
  </header>

  {{ menu }}

</div>

<!-- Mobile nav drawer — slide in from left -->
<div class="mobile-nav" id="js-mobile-nav" aria-hidden="true">

  <div class="mobile-nav__header">
    <span class="mobile-nav__title">MENU</span>
    <button class="mobile-nav__close" id="js-mobile-nav-close" aria-label="Zapri meni">
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <div class="mobile-nav__section-label">NAKUPUJ</div>
  <!-- OC categories cloned here by JS (Deklice, Dečki, Nosečnice …) -->
  <ul class="mobile-nav__list" id="js-mobile-nav-list"></ul>

  <!-- Paket presenečenja — hardcoded with explicit sub-links -->
  <ul class="mobile-nav__list">
    <li class="mobile-nav__item" id="js-mobile-paket">
      <button type="button" class="mobile-nav__item-row" aria-expanded="false" aria-label="Paket presenečenja">
        <img class="mobile-nav__cat-img" src="image/catalog/assets/kategorije/paket-presenecenja-kategorije-otroski-koticek-001.jpg" alt="" aria-hidden="true" width="50" height="50" />
        <span class="mobile-nav__cat-info">
          <span class="mobile-nav__cat-name">Paket presenečenja</span>
        </span>
        <span class="mobile-nav__chevron" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </span>
      </button>
      <ul class="mobile-nav__sub-list">
        <li><a id="js-paket-link-deklice" href="{{ base }}index.php?route=product/category&path=226_247">Za deklice</a></li>
        <li><a id="js-paket-link-decke" href="{{ base }}index.php?route=product/category&path=225_248">Za dečke</a></li>
      </ul>
    </li>
  </ul>

  <div class="mobile-nav__section-label mobile-nav__section-label--ruled">PRODAJ</div>
  <ul class="mobile-nav__list">
    <li class="mobile-nav__item">
      <a href="{{ base }}index.php?route=information/information&information_id=9" class="mobile-nav__link mobile-nav__link--bold">
        <img class="mobile-nav__cat-img" src="image/catalog/assets/homepage/izprazni-omaro.png" alt="" aria-hidden="true" width="50" height="57" />
        IZPRAZNI svojo OMARO
      </a>
    </li>
  </ul>

  <div class="mobile-nav__section-label mobile-nav__section-label--ruled">RAČUN</div>
  <ul class="mobile-nav__list">
    <li class="mobile-nav__item">
      <a href="{{ wishlist }}" class="mobile-nav__link mobile-nav__link--icon">
        <svg class="mobile-nav__item-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        Shranjeni artikli
      </a>
    </li>
    <li class="mobile-nav__item">
      <a href="{{ account }}" class="mobile-nav__link mobile-nav__link--icon">
        <svg class="mobile-nav__item-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        {% if logged %}Moj račun{% else %}Prijava / Registracija{% endif %}
      </a>
    </li>
  </ul>

  <ul class="mobile-nav__list" id="js-mobile-info-list"></ul>

</div>

<!-- Dark overlay behind the drawer -->
<div class="mobile-nav-overlay" id="js-mobile-overlay" aria-hidden="true"></div>

<!-- Mobile search bottom sheet -->
<div class="search-sheet-overlay" id="js-search-overlay"></div>
<div class="search-sheet" id="js-search-sheet">
  <div class="search-sheet__handle"></div>
  <div class="search-sheet__field">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="js-search-input" class="search-sheet__input" placeholder="Išči oblačila, velikosti, znamke..." autocomplete="off" />
    <button type="button" class="search-sheet__clear" id="js-search-clear" style="display:none;">&times;</button>
  </div>
  <div class="search-sheet__cats">
    <a href="{{ base }}index.php?route=product/category&path=226" class="search-sheet__cat">Deklice</a>
    <a href="{{ base }}index.php?route=product/category&path=225" class="search-sheet__cat">Dečki</a>
    <a href="{{ base }}index.php?route=product/category&path=63" class="search-sheet__cat">Nosečnice</a>
    <a href="{{ base }}index.php?route=product/search" class="search-sheet__cat">Vse</a>
  </div>
</div>

<!-- Sticky compact nav — populated + shown by JS on scroll -->
<div class="sticky-nav" id="js-sticky-nav" aria-hidden="true">
  <div class="container">
    <div class="sticky-nav__inner">
      <ul class="sticky-nav__cats" id="js-sticky-cats"></ul>
      <div class="sticky-nav__actions">

        <button type="button" class="sticky-nav__btn" id="js-sticky-search" aria-label="Iskanje">
          <svg class="sticky-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </button>

        <div class="sticky-nav__action dropdown">
          <a href="{{ account }}" class="sticky-nav__btn dropdown-toggle" data-toggle="dropdown" aria-label="{{ text_account }}">
            <svg class="sticky-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </a>
          <ul class="dropdown-menu dropdown-menu-right">
            {% if logged %}
            <li><a href="{{ account }}">{{ text_account }}</a></li>
            <li><a href="{{ order }}">{{ text_order }}</a></li>
            <li><a href="{{ logout }}">{{ text_logout }}</a></li>
            {% else %}
            <li><a href="{{ register }}">{{ text_register }}</a></li>
            <li><a href="{{ login }}">{{ text_login }}</a></li>
            {% endif %}
          </ul>
        </div>

        <a href="{{ wishlist }}" class="sticky-nav__btn" aria-label="{{ text_wishlist }}">
          <svg class="sticky-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        </a>

        <div class="sticky-nav__action dropdown" id="js-sticky-cart-wrap">
          <button type="button" class="sticky-nav__btn dropdown-toggle" id="js-sticky-cart" data-toggle="dropdown" aria-label="Košarica">
            <span class="cart-icon-wrap">
              <svg class="sticky-nav__icon icon-cart" aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            </span>
            <span class="sticky-nav__cart-price"></span>
          </button>
          <!-- dropdown cloned from #cart by syncStickyCart() -->
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Floating toast — minimal pill, drops from top center -->
<div id="oc-toast" class="oc-toast" role="status" aria-live="polite" aria-atomic="true">
  <span class="oc-toast__dot"></span>
  <span class="oc-toast__msg"></span>
</div>
