              </p>
              {% if product.in_cart is defined and product.in_cart %}
              <button class="product-card__cart product-card__cart--in-cart" type="button" disabled aria-label="V košarici">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
              {% elseif product.reservation_status is defined and (product.reservation_status == 'reserved' or product.reservation_status == 'sold') %}
              <button class="product-card__cart product-card__cart--disabled" type="button" disabled aria-label="Ni na voljo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              </button>
              {% else %}
              <button class="product-card__cart" type="button" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum }}');" aria-label="{{ button_cart }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              </button>
              {% endif %}
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {{ content_top }}
    {{ content_bottom }}

  </div>
</div>

