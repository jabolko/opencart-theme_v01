{# ── Gallery swipe + dots ── #}
<script type="text/javascript"><!--
(function(){
  var track = document.getElementById('js-pdp-track');
  var dots = document.querySelectorAll('.pdp-gallery__dot');
  if (!track || dots.length < 2) return;

  var currentIndex = 0;
  var startX = 0;
  var diffX = 0;
  var dragging = false;

  var swiped = false;

  track.addEventListener('touchstart', function(e) {
    startX = e.touches[0].clientX;
    dragging = true;
    swiped = false;
  }, { passive: true });

  track.addEventListener('touchmove', function(e) {
    if (!dragging) return;
    diffX = e.touches[0].clientX - startX;
    if (Math.abs(diffX) > 10) swiped = true;
  }, { passive: true });

  track.addEventListener('touchend', function() {
    if (!dragging) return;
    dragging = false;
    if (Math.abs(diffX) > 50) {
      if (diffX < 0 && currentIndex < dots.length - 1) currentIndex++;
      else if (diffX > 0 && currentIndex > 0) currentIndex--;
    }
    track.style.transform = 'translateX(-' + (currentIndex * 100) + '%)';
    for (var i = 0; i < dots.length; i++) {
      dots[i].classList.toggle('is-active', i === currentIndex);
    }
    diffX = 0;
  });

  // Prevent Magnific Popup opening during swipe
  var links = track.querySelectorAll('a');
  for (var i = 0; i < links.length; i++) {
    links[i].addEventListener('click', function(e) {
      if (swiped) { e.preventDefault(); e.stopPropagation(); }
    });
  }
})();
//--></script>

{# ── Desktop thumbnail click (swap main image) ── #}
<script type="text/javascript"><!--
(function(){
  var slides = document.querySelectorAll('.pdp-gallery__slide');
  var thumbs = document.querySelectorAll('.pdp-gallery__thumb-desktop');
  if (thumbs.length < 2) return;

  // Mark first slide active
  if (slides.length > 0) slides[0].classList.add('is-active-desktop');

  for (var i = 0; i < thumbs.length; i++) {
    thumbs[i].addEventListener('click', function() {
      var idx = parseInt(this.getAttribute('data-index'));
      // Update thumbs
      for (var j = 0; j < thumbs.length; j++) thumbs[j].classList.remove('is-active');
      this.classList.add('is-active');
      // Update slides
      for (var j = 0; j < slides.length; j++) {
        slides[j].classList.remove('is-active-desktop');
        slides[j].style.display = 'none';
      }
      if (slides[idx]) {
        slides[idx].classList.add('is-active-desktop');
        slides[idx].style.display = 'block';
      }
    });
  }
})();
//--></script>

{# ── Magnific Popup gallery ── #}
<script type="text/javascript"><!--
$(document).ready(function() {
  $('.pdp-gallery__track').magnificPopup({
    type: 'image',
    delegate: 'a',
    gallery: {
      enabled: true,
      navigateByImgClick: true,
      tCounter: '%curr% / %total%'
    },
    callbacks: {
      open: function() {
        var popup = this;
        var container = $(popup.container);
        container.find('.mfp-nav-btn').remove();
        var prevBtn = $('<button class="mfp-nav-btn mfp-nav-btn--prev" type="button" aria-label="Prejšnja"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>');
        var nextBtn = $('<button class="mfp-nav-btn mfp-nav-btn--next" type="button" aria-label="Naslednja"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>');
        prevBtn.on('click', function(e) { e.stopPropagation(); popup.prev(); });
        nextBtn.on('click', function(e) { e.stopPropagation(); popup.next(); });
        container.append(prevBtn, nextBtn);

        // Swipe inside lightbox
        var sx = 0, sd = 0;
        container[0].addEventListener('touchstart', function(e) { sx = e.touches[0].clientX; sd = 0; }, { passive: true });
        container[0].addEventListener('touchmove', function(e) { sd = e.touches[0].clientX - sx; }, { passive: true });
        container[0].addEventListener('touchend', function() {
          if (Math.abs(sd) > 50) { if (sd < 0) popup.next(); else popup.prev(); }
          sd = 0;
        });
      }
    }
  });
});
//--></script>

{# ── OC cart AJAX ── #}
<script type="text/javascript"><!--
$('#button-cart').on('click', function() {
  $.ajax({
    url: 'index.php?route=checkout/cart/add',
    type: 'post',
    data: $('#product input[type=\'text\'], #product input[type=\'hidden\'], #product input[type=\'radio\']:checked, #product input[type=\'checkbox\']:checked, #product select, #product textarea'),
    dataType: 'json',
    beforeSend: function() { $('#button-cart').button('loading'); },
    complete: function() { if (!$('#button-cart').prop('disabled')) { $('#button-cart').button('reset'); } },
    success: function(json) {
      $('.alert-dismissible, .text-danger').remove();
      $('.pdp-options__group').removeClass('has-error');
      if (json['error']) {
        if (json['error']['option']) {
          for (i in json['error']['option']) {
            var element = $('#input-option' + i.replace('_', '-'));
            element.after('<div class="text-danger">' + json['error']['option'][i] + '</div>');
          }
          $('.text-danger').parent().addClass('has-error');
        }
        // Show reservation / already-in-cart error as toast
        if (json['error']['warning']) {
          if (typeof showToast === 'function') {
            showToast(json['error']['warning']);
          }
          // Disable the add-to-cart button
          $('#button-cart').prop('disabled', true).addClass('pdp-cart-btn--disabled').html('Že v košarici drugega kupca');
        }
      }
      if (json['success']) {
        // Use theme toast instead of Bootstrap alert
        if (typeof showToast === 'function') {
          showToast(json['success']);
        }
        // Disable button — product is now reserved by this user
        $('#button-cart').prop('disabled', true).removeClass('pdp-cart-btn--disabled').addClass('pdp-cart-btn--in-cart').html('<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> V košarici');
        // Show gallery label
        var lbl = document.getElementById('js-pdp-label');
        if (lbl) {
          lbl.className = 'product-label product-label--in-cart pdp-gallery__label';
          lbl.textContent = 'V KOŠARICI';
          lbl.style.display = '';
        }
        $('#cart > button').html('<span id="cart-total"><i class="fa fa-shopping-cart"></i> ' + json['total'] + '</span>');
        $('#cart > ul').load('index.php?route=common/cart/info ul li');
      }
    },
    error: function(xhr, ajaxOptions, thrownError) {
      alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
    }
  });
});
//--></script>

