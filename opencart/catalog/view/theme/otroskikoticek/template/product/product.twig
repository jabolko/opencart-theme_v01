{{ header }}
<div id="product-product" class="pdp-page" data-product-id="{{ product_id }}">
  <div id="content" class="container">

    {# ── Breadcrumb ── #}
    <ul class="pdp-breadcrumb">
      {% for breadcrumb in breadcrumbs %}
      <li>
        {% if not loop.last %}
        <a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
        <span class="pdp-breadcrumb__sep">/</span>
        {% else %}
        <span class="pdp-breadcrumb__current">{{ breadcrumb.text }}</span>
        {% endif %}
      </li>
      {% endfor %}
    </ul>

    {# ── Desktop: two-column layout (gallery | info) ── #}
    <div class="pdp-layout">

    {# ── Image gallery (swipe carousel on mobile, dot indicators) ── #}
    <div class="pdp-gallery" id="js-pdp-gallery">
      {% if reservation_status == 'in_cart' %}
      <span class="product-label product-label--in-cart pdp-gallery__label" id="js-pdp-label">V KOŠARICI</span>
      {% elseif reservation_status == 'reserved' %}
      <span class="product-label product-label--reserved pdp-gallery__label" id="js-pdp-label">REZERVIRANO</span>
      {% elseif reservation_status == 'sold' %}
      <span class="product-label product-label--sold pdp-gallery__label" id="js-pdp-label">PRODANO</span>
      {% else %}
      <span class="product-label pdp-gallery__label" id="js-pdp-label" style="display:none;"></span>
      {% endif %}
      <div class="pdp-gallery__track" id="js-pdp-track">
        {% if thumb %}
        <div class="pdp-gallery__slide">
          <a href="{{ popup }}">
            <picture>
              <source media="(min-width: 768px)" srcset="{{ popup }}">
              <img src="{{ thumb }}" alt="{{ heading_title }}" loading="eager" />
            </picture>
          </a>
        </div>
        {% endif %}
        {% if images %}
        {% for image in images %}
        <div class="pdp-gallery__slide">
          <a href="{{ image.popup }}">
            <picture>
              <source media="(min-width: 768px)" srcset="{{ image.popup }}">
              <img src="{{ image.thumb }}" alt="{{ heading_title }}" loading="lazy" />
            </picture>
          </a>
        </div>
        {% endfor %}
        {% endif %}
      </div>
      {% set total_images = 1 + (images ? images|length : 0) %}
      {% if total_images > 1 %}
      <div class="pdp-gallery__dots" id="js-pdp-dots">
        {% for i in 1..total_images %}
        <span class="pdp-gallery__dot{% if loop.first %} is-active{% endif %}"></span>
        {% endfor %}
      </div>
      {% endif %}
      <button class="pdp-gallery__fav" type="button" onclick="wishlist.add('{{ product_id }}');" aria-label="{{ button_wishlist }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </button>

      {# Desktop thumbnail strip #}
      {% if images %}
      <div class="pdp-gallery__thumbs-desktop">
        <button class="pdp-gallery__thumb-desktop is-active" data-index="0" type="button">
          <img src="{{ thumb }}" alt="{{ heading_title }}" width="70" height="70" />
        </button>
        {% for image in images %}
        <button class="pdp-gallery__thumb-desktop" data-index="{{ loop.index }}" type="button">
          <img src="{{ image.thumb }}" alt="{{ heading_title }}" width="70" height="70" />
        </button>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    {# ── Product info ── #}
    <div class="pdp-info">

      {# Brand #}
      {% if manufacturer %}
      <a href="{{ manufacturers }}" class="pdp-info__brand">{{ manufacturer }}</a>
      {% endif %}

      {# Title #}
      <h1 class="pdp-info__title">{{ heading_title }}</h1>

      {# Scarcity — hide when sold #}
      {% if reservation_status != 'sold' %}
      <div class="pdp-info__scarcity">● Samo 1 na voljo</div>
      {% endif %}

      {# Price #}
      {% if price %}
      <div class="pdp-info__price">
        {% if special %}
        <span class="pdp-info__price-new">{{ special }}</span>
        <span class="pdp-info__price-old">{{ price }}</span>
        {% else %}
        <span class="pdp-info__price-current">{{ price }}</span>
        {% endif %}
      </div>
      {% endif %}

      {# Add to cart #}
      <div id="product">
        {% if options %}
        <div class="pdp-options">
          {% for option in options %}
          {% if option.type == 'select' %}
          <div class="pdp-options__group{% if option.required %} required{% endif %}">
            <label for="input-option{{ option.product_option_id }}">{{ option.name }}</label>
            <select name="option[{{ option.product_option_id }}]" id="input-option{{ option.product_option_id }}" class="pdp-options__select">
              <option value="">{{ text_select }}</option>
              {% for option_value in option.product_option_value %}
              <option value="{{ option_value.product_option_value_id }}">{{ option_value.name }}{% if option_value.price %} ({{ option_value.price_prefix }}{{ option_value.price }}){% endif %}</option>
              {% endfor %}
            </select>
          </div>
          {% endif %}
          {% if option.type == 'radio' %}
          <div class="pdp-options__group{% if option.required %} required{% endif %}">
            <label>{{ option.name }}</label>
            <div class="pdp-options__radios" id="input-option{{ option.product_option_id }}">
              {% for option_value in option.product_option_value %}
              <label class="pdp-options__radio">
                <input type="radio" name="option[{{ option.product_option_id }}]" value="{{ option_value.product_option_value_id }}" />
                {{ option_value.name }}{% if option_value.price %} ({{ option_value.price_prefix }}{{ option_value.price }}){% endif %}
              </label>
              {% endfor %}
            </div>
          </div>
          {% endif %}
          {% if option.type == 'checkbox' %}
          <div class="pdp-options__group{% if option.required %} required{% endif %}">
            <label>{{ option.name }}</label>
            <div class="pdp-options__checkboxes" id="input-option{{ option.product_option_id }}">
              {% for option_value in option.product_option_value %}
              <label class="pdp-options__checkbox">
                <input type="checkbox" name="option[{{ option.product_option_id }}][]" value="{{ option_value.product_option_value_id }}" />
                {{ option_value.name }}{% if option_value.price %} ({{ option_value.price_prefix }}{{ option_value.price }}){% endif %}
              </label>
              {% endfor %}
            </div>
          </div>
          {% endif %}
          {% if option.type == 'text' %}
          <div class="pdp-options__group{% if option.required %} required{% endif %}">
            <label for="input-option{{ option.product_option_id }}">{{ option.name }}</label>
            <input type="text" name="option[{{ option.product_option_id }}]" value="{{ option.value }}" placeholder="{{ option.name }}" id="input-option{{ option.product_option_id }}" class="pdp-options__input" />
          </div>
          {% endif %}
          {% endfor %}
        </div>
        {% endif %}

        <input type="hidden" name="product_id" value="{{ product_id }}" />
        <input type="hidden" name="quantity" value="{{ minimum }}" />

        {% if reservation_status == 'in_cart' %}
        <button type="button" class="pdp-cart-btn pdp-cart-btn--in-cart" disabled>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          V košarici
        </button>
        {% elseif reservation_status == 'reserved' %}
        <button type="button" class="pdp-cart-btn pdp-cart-btn--disabled" disabled>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          Že v košarici drugega kupca
        </button>
        {% elseif reservation_status == 'sold' %}
        <button type="button" class="pdp-cart-btn pdp-cart-btn--disabled" disabled>Prodano</button>
        {% else %}
        <button type="button" id="button-cart" class="pdp-cart-btn" data-loading-text="{{ text_loading }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
          </svg>
          V košarico
        </button>
        {% endif %}

        {% if minimum > 1 %}
        <p class="pdp-info__minimum">{{ text_minimum }}</p>
        {% endif %}
      </div>

      {# Guarantee strip #}
      <div class="pdp-guarantee">
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          14 dni za vračilo
        </span>
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Brezplačna poštnina nad 55€
        </span>
        <a href="https://g.page/otroskikoticek" target="_blank" rel="noopener" class="pdp-guarantee__google">
          <svg width="14" height="14" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <span class="pdp-guarantee__stars">★★★★★</span>
          <strong>4.9</strong> (150+)
        </a>
      </div>

      {# ── Opis (always open) ── #}
      {% if description %}
      <div class="pdp-section">
        <h3 class="pdp-section__title">Opis</h3>
        <div class="pdp-section__text">{{ description }}</div>
      </div>
      {% endif %}

      {# ── Podrobnosti (always open) ── #}
      <div class="pdp-section">
        <div class="pdp-section__header">
          <h3 class="pdp-section__title">Podrobnosti</h3>
          <span class="pdp-section__model">{{ model }}</span>
        </div>
        <div class="pdp-details">
          {% if manufacturer %}
          <div class="pdp-details__row">
            <span>Znamka</span>
            <span><a href="{{ manufacturers }}">{{ manufacturer }}</a></span>
          </div>
          {% endif %}
          {% if attribute_groups %}
          {% for attribute_group in attribute_groups %}
          {% for attribute in attribute_group.attribute %}
          {% if attribute.name != 'Opis' and attribute.name != 'Znamka' %}
          <div class="pdp-details__row">
            <span>{{ attribute.name }}</span>
            <span>{{ attribute.text }}</span>
          </div>
          {% endif %}
          {% endfor %}
          {% endfor %}
          {% endif %}
        </div>
      </div>

      {# ── Google review pill (mobile only) ── #}
      <a href="https://g.page/otroskikoticek" target="_blank" rel="noopener" class="pdp-google-pill">
        <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <span class="pdp-google-pill__score">4.9</span>
        <span class="pdp-google-pill__stars">★★★★★</span>
        <span class="pdp-google-pill__count">150+ ocen</span>
      </a>

      {# ── Contact CTA ── #}
      <div class="pdp-contact">
        <span class="pdp-contact__text">Imaš vprašanje? <span style="margin-left:4px">Pokliči nas: <a href="tel:+38640611233">040 611 233</a></span></span>
        <button class="pdp-contact__info" id="js-hours-toggle" type="button" aria-label="Delovni čas">?</button>
        <div class="pdp-contact__popup" id="js-hours-popup">
          <div class="pdp-contact__popup-title">Delovni čas</div>
          <div class="pdp-contact__popup-row"><span>Tor – Pet</span><span>10:00 – 18:00</span></div>
          <div class="pdp-contact__popup-row"><span>Sobota</span><span>9:00 – 12:00</span></div>
          <div class="pdp-contact__popup-row"><span class="pdp-contact__popup-closed">Pon, Ned</span><span class="pdp-contact__popup-closed">Zaprto</span></div>
        </div>
      </div>
      <script type="text/javascript"><!--
      (function(){
        var btn = document.getElementById('js-hours-toggle');
        var popup = document.getElementById('js-hours-popup');
        if (!btn || !popup) return;
        btn.addEventListener('click', function(e) { e.stopPropagation(); popup.classList.toggle('is-open'); });
        document.addEventListener('click', function(e) { if (!popup.contains(e.target)) popup.classList.remove('is-open'); });
      })();
      //--></script>

      {# ── Sell CTA ── #}
      <a href="{{ base }}index.php?route=information/information&information_id=4" class="pdp-sell">
        <div class="pdp-sell__content">
          <h3 class="pdp-sell__title">Polna omara oblačil?</h3>
          <p class="pdp-sell__text">Prodaj svoja otroška oblačila in izprazni omaro.</p>
        </div>
        <span class="pdp-sell__cta">
          Prodaj pri nas
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>

      {# ── Eco + Trust tabbed section ── #}
      <div class="pdp-impact">
      <div class="pdp-impact__tabs">
        <button class="pdp-impact__tab is-active" data-target="js-impact-eco" type="button">Vpliv tekstilne industrije</button>
        <button class="pdp-impact__tab" data-target="js-impact-trust" type="button">Naša garancija kakovosti</button>
      </div>

      {# Eco panel #}
      <div class="pdp-impact__panel is-active" id="js-impact-eco">
        <div class="pdp-eco__item">
          <div class="pdp-eco__number pdp-eco__number--people">0,50<span class="pdp-eco__unit">€</span><small>plačilo / uro</small></div>
          <div class="pdp-eco__body">
            <div class="pdp-eco__item-title">Poceni delovna sila</div>
            <div class="pdp-eco__item-text">Delavci v tretjem svetu — tudi otroci — delajo za manj kot pol evra na uro</div>
          </div>
        </div>

        <div class="pdp-eco__item">
          <div class="pdp-eco__number pdp-eco__number--co2">10<span class="pdp-eco__unit">%</span><small>emisij CO₂</small></div>
          <div class="pdp-eco__body">
            <div class="pdp-eco__item-title">Emisije toplogrednih plinov</div>
            <div class="pdp-eco__item-text">Več kot vsi mednarodni leti in pomorski promet skupaj</div>
          </div>
        </div>

        <div class="pdp-eco__item">
          <div class="pdp-eco__number pdp-eco__number--water">93<span class="pdp-eco__unit">mrd</span><small>m³ vode</small></div>
          <div class="pdp-eco__body">
            <div class="pdp-eco__item-title">Poraba vode</div>
            <div class="pdp-eco__item-text">Enako kot potrebuje 200 milijonov ljudi letno</div>
          </div>
        </div>

        <p class="pdp-eco__statement">Nežno rabljeno ne izkorišča delovne sile, ne ustvarja emisij in ne porablja vode.</p>
      </div>

      {# Trust panel #}
      <div class="pdp-impact__panel" id="js-impact-trust">
        <div class="pdp-eco__item">
          <div class="pdp-eco__number pdp-eco__number--trust">10x<small>pregledano</small></div>
          <div class="pdp-eco__body">
            <div class="pdp-eco__item-title">Vsak artikel pregledamo 10-krat</div>
            <div class="pdp-eco__item-text">Od sprejema do pakiranja — pri etiketiranju, fotografiranju, sortiranju in uvrščanju na police</div>
          </div>
        </div>

        <div class="pdp-eco__item">
          <div class="pdp-eco__number pdp-eco__number--trust">14<small>dni za vračilo</small></div>
          <div class="pdp-eco__body">
            <div class="pdp-eco__item-title">Brez pojasnila</div>
            <div class="pdp-eco__item-text">Če s čim nisi zadovoljna, nam artikel vrni v 14 dneh — brez vprašanj</div>
          </div>
        </div>

        <p class="pdp-eco__statement">Zagotavljam ti, da je vsak artikel res samo nežno rabljen.</p>
      </div>
    </div>

    <script type="text/javascript"><!--
    (function(){
      var tabs = document.querySelectorAll('.pdp-impact__tab');
      var panels = document.querySelectorAll('.pdp-impact__panel');
      for (var i = 0; i < tabs.length; i++) {
        tabs[i].addEventListener('click', function(){
          for (var j = 0; j < tabs.length; j++) { tabs[j].classList.remove('is-active'); }
          for (var j = 0; j < panels.length; j++) { panels[j].classList.remove('is-active'); }
          this.classList.add('is-active');
          var panel = document.getElementById(this.getAttribute('data-target'));
          if (panel) panel.classList.add('is-active');
        });
      }
    })();
    //--></script>

    </div>{# /.pdp-info #}
    </div>{# /.pdp-layout #}

    {# ── Similar products (more from this brand) ── #}
    {% if similar_products %}
    <div class="pdp-similar">
      <h2 class="pdp-similar__title">{{ similar_title }}</h2>
      <div class="pdp-similar__scroller">
        {% for product in similar_products %}
        <article class="product-card product-card--scroll">
          <div class="product-card__media">
            <a href="{{ product.href }}" class="product-card__img-wrap">
              <div class="product-card__img">
                <div class="product-card__labels">
                  {% if product.reservation_status == 'in_cart' %}
                    <span class="product-label product-label--in-cart">V KOŠARICI</span>
                  {% elseif product.reservation_status == 'reserved' %}
                    <span class="product-label product-label--reserved">REZERVIRANO</span>
                  {% elseif product.reservation_status == 'sold' %}
                    <span class="product-label product-label--sold">PRODANO</span>
                  {% endif %}
                </div>
                <img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy" />
              </div>
            </a>
            <button class="product-card__fav" type="button" onclick="wishlist.add('{{ product.product_id }}');" aria-label="{{ button_wishlist }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>
          <div class="product-card__body">
            {% if product.manufacturer %}
            <p class="product-card__manufacturer">{{ product.manufacturer }}</p>
            {% endif %}
            <a href="{{ product.href }}" class="product-card__name">{{ product.name }}</a>
            <div class="product-card__footer">
              <p class="product-card__price">
                {% if product.special %}
                <span class="product-card__price-new">{{ product.special }}</span>
                <span class="product-card__price-old">{{ product.price }}</span>
                {% else %}
                {{ product.price }}
                {% endif %}
              </p>
              {% if product.in_cart %}
              <button class="product-card__cart product-card__cart--in-cart" type="button" disabled aria-label="V košarici">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
              {% elseif product.reservation_status == 'reserved' or product.reservation_status == 'sold' %}
              <button class="product-card__cart product-card__cart--disabled" type="button" disabled aria-label="Ni na voljo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              </button>
              {% else %}
              <button class="product-card__cart" type="button" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum }}');" aria-label="{{ button_cart }}">
