{{ header }}
<div id="checkout-checkout" class="ck-page">

  {# ── Checkout Header (minimal — no nav, just logo + secure + phone) ── #}
  <div class="ck-header-wrap">
  <div class="ck-header">
    <a class="ck-header__back" href="{{ base }}index.php?route=checkout/cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      <span>Nazaj</span>
    </a>
    <a class="ck-header__logo" href="{{ base }}">Otroški kotiček</a>
    <div class="ck-header__secure">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="#7d9478" stroke="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Varna povezava</span>
    </div>
  </div>
  </div>

  {# ── Progress Bar ── #}
  <div class="ck-progress" id="js-ck-progress">
    <div class="ck-progress__step is-active" data-step="1">
      <div class="ck-progress__dot">1</div>
      <span class="ck-progress__label">Podatki</span>
    </div>
    <div class="ck-progress__line"></div>
    <div class="ck-progress__step" data-step="2">
      <div class="ck-progress__dot">2</div>
      <span class="ck-progress__label">Dostava</span>
    </div>
    <div class="ck-progress__line"></div>
    <div class="ck-progress__step" data-step="3">
      <div class="ck-progress__dot">3</div>
      <span class="ck-progress__label">Plačilo</span>
    </div>
    <div class="ck-progress__line"></div>
    <div class="ck-progress__step" data-step="4">
      <div class="ck-progress__dot">4</div>
      <span class="ck-progress__label">Potrditev</span>
    </div>
  </div>

  {# ── Total Bar ── #}
  <div class="ck-total-bar">
    <div class="ck-total-bar__sum">
      <span class="ck-total-bar__label">Skupaj:</span>
      <span class="ck-total-bar__amount">{{ cart_total }}</span>
      <span class="ck-total-bar__count">({{ cart_count }} {% if cart_count == 1 %}artikel{% else %}artikli{% endif %})</span>
    </div>
    <div class="ck-total-bar__pay">
      <span class="cart-pay cart-pay--visa">VISA</span>
      <span class="cart-pay cart-pay--mc"><i></i><i></i></span>
      <span class="cart-pay cart-pay--pp">Pay<em>Pal</em></span>
      <span class="cart-pay cart-pay--svg" aria-label="Google Pay"><svg viewBox="0 0 120 80" fill="none"><rect width="120" height="80" rx="4" fill="white"/><path d="M57.54 27v8.98h5.54c1.32 0 2.41-.44 3.27-1.33.89-.88 1.33-1.94 1.33-3.16 0-1.2-.44-2.24-1.33-3.13-.89-.91-1.98-1.37-3.3-1.37h-5.51zm0 12.14v10.42h-3.31V23.84h8.78c2.23 0 4.12.74 5.68 2.23 1.58 1.48 2.38 3.3 2.38 5.43 0 2.18-.79 4-2.38 5.46-1.53 1.46-3.43 2.19-5.68 2.19h-5.47z" fill="#3C4043"/><path d="M74.41 44.17c0 .86.37 1.58 1.1 2.16.73.57 1.59.86 2.57.86 1.39 0 2.63-.51 3.72-1.54 1.1-1.03 1.64-2.24 1.64-3.63-.98-.81-2.42-1.22-4.32-1.22-1.34 0-2.46.33-3.36.97-.9.65-1.35 1.45-1.35 2.4zm4.28-12.79c2.45 0 4.38.65 5.79 1.96 1.41 1.31 2.12 3.1 2.12 5.37v10.85h-3.17v-2.44h-.14c-1.37 2.01-3.19 3.02-5.47 3.02-1.94 0-3.57-.58-4.87-1.72-1.31-1.15-1.96-2.59-1.96-4.31 0-1.82.69-3.27 2.07-4.35 1.38-1.08 3.22-1.62 5.52-1.62 1.96 0 3.58.36 4.85 1.08v-.76c0-1.15-.46-2.12-1.37-2.93-.83-.79-1.96-1.22-3.14-1.2-1.85 0-3.31.78-4.39 2.34l-2.91-1.83c1.6-2.3 3.98-3.45 7.12-3.45z" fill="#3C4043"/><path d="M104.77 31.96L93.73 57.32h-3.42l4.1-8.87-7.26-16.49h3.6l5.25 12.65h.07l5.11-12.65h3.6z" fill="#3C4043"/><path d="M44.17 36.89c0-1.04-.09-2.04-.26-3.01H29.96v5.69h7.99c-.33 1.84-1.4 3.46-3 4.49v3.7h4.77c2.79-2.58 4.42-6.38 4.42-10.87z" fill="#4285F4"/><path d="M29.96 51.34c3.99 0 7.36-1.31 9.81-3.57l-4.77-3.7c-1.33.89-3.04 1.41-5.04 1.41-3.86 0-7.14-2.6-8.31-6.1h-4.91v3.81c2.51 5 7.63 8.15 13.22 8.15z" fill="#34A853"/><path d="M21.65 39.39c-.62-1.84-.62-3.82 0-5.66v-3.81h-4.91A17.4 17.4 0 0 0 15.16 36.56c0 2.39.57 4.64 1.58 6.64l4.91-3.81z" fill="#FABB05"/><path d="M29.96 27.63c2.18 0 4.14.75 5.68 2.22l4.22-4.22c-2.56-2.38-5.9-3.85-9.9-3.85-5.59 0-10.7 3.15-13.22 8.15l4.91 3.81c1.17-3.5 4.45-6.1 8.31-6.1z" fill="#E94235"/></svg></span>
      <span class="cart-pay cart-pay--svg" aria-label="Apple Pay"><svg viewBox="0 0 120 80" fill="none"><rect width="120" height="80" rx="4" fill="white"/><path d="M55.55 22.9C61.1 22.9 64.97 26.73 64.97 32.3c0 5.59-3.94 9.43-9.55 9.43H49.27v9.77h-4.44V22.9h10.72zm-6.28 15.1h5.09c3.87 0 6.07-2.08 6.07-5.69 0-3.6-2.2-5.67-6.04-5.67h-5.12v11.36z" fill="#000"/><path d="M66.13 45.58c0-3.65 2.79-5.89 7.75-6.16l5.71-.34v-1.6c0-2.32-1.57-3.71-4.18-3.71-2.48 0-4.02 1.19-4.4 3.05h-4.04c.24-3.77 3.45-6.54 8.6-6.54 5.06 0 8.29 2.68 8.29 6.86V51.5h-4.1v-3.43h-.1c-1.2 2.32-3.84 3.79-6.58 3.79-4.08 0-6.94-2.54-6.94-6.28zm13.46-1.88v-1.65l-5.13.32c-2.56.18-4 1.31-4 3.1 0 1.82 1.5 3.01 3.8 3.01 2.99 0 5.33-1.97 5.33-4.78z" fill="#000"/><path d="M87.72 59.18V55.7c.32.08 1.03.08 1.39.08 1.98 0 3.05-.83 3.7-2.97l.38-1.27-7.53-20.87h4.64l5.27 16.97h.08l5.27-16.97h4.52l-7.81 21.94c-1.78 5.05-3.85 6.68-8.17 6.68-.36 0-1.43-.04-1.75-.1z" fill="#000"/><path d="M31.74 25.7c1.07-1.34 1.8-3.14 1.6-4.97-1.57.08-3.48 1.03-4.58 2.37-1 1.15-1.87 3.02-1.64 4.78 1.76.15 3.52-.88 4.62-2.18z" fill="#000"/><path d="M33.32 28.22c-2.55-.15-4.72 1.45-5.94 1.45-1.22 0-3.09-1.37-5.11-1.34-2.63.04-5.07 1.52-6.4 3.89-2.74 4.73-.74 11.74 1.93 15.59 1.3 1.91 2.86 4 4.91 3.93 1.95-.08 2.71-1.26 5.07-1.26s3.05 1.26 5.11 1.22c2.13-.04 3.47-1.87 4.76-3.77 1.49-2.17 2.1-4.27 2.14-4.39-.04-.04-4.12-1.56-4.15-6.25-.04-3.93 3.24-5.79 3.39-5.91-1.83-2.7-4.69-3.01-5.68-3.08z" fill="#000"/></svg></span>
    </div>
  </div>

  {% if error_warning %}
  <div class="ck-layout">
    <div class="ck-layout__main">
      <div class="ck-panel" style="margin-bottom: 0.15rem;">
        <div style="padding: 1rem;">
          <div class="alert alert-danger alert-dismissible" style="margin-bottom: 0;">{{ error_warning }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <div class="ck-layout">
    {# ── LEFT: Accordion Steps ── #}
    <div class="ck-layout__main">
      <div class="panel-group" id="accordion">

        {# Step 1: Hidden — OC JS still needs this panel to exist #}
        <div class="ck-panel ck-panel--hidden" data-step="1" hidden>
          <div class="panel-heading">
            <h4 class="panel-title">{{ text_checkout_option }}</h4>
          </div>
          <div class="panel-collapse collapse" id="collapse-checkout-option">
            <div class="panel-body"></div>
          </div>
        </div>

        {# Step 1 (merged): Pills nav + Guest/Register/Login form #}
        <div class="ck-panel" data-step="1">
          <div class="panel-heading">
            <h4 class="panel-title">{% if not logged %}{{ text_checkout_payment_address }}{% else %}{{ text_checkout_payment_address }}{% endif %}</h4>
          </div>
          <div class="panel-collapse collapse" id="collapse-payment-address">
            <div class="panel-body">
              {% if not logged %}
              {# V1 Pills Nav — only for guests #}
              <div class="ck-pills" id="js-ck-pills">
                <div class="ck-pills__tabs">
                  <button type="button" class="ck-pills__pill is-active" id="js-pill-guest">Gost</button>
                  <button type="button" class="ck-pills__pill" id="js-pill-register">Registracija</button>
                </div>
                <a class="ck-pills__login" id="js-pill-login">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                  Prijava
                </a>
              </div>
              {% endif %}
              {# OC AJAX content loads here #}
            </div>
          </div>
        </div>

        {# Step 3: Shipping Address (only if different) #}
        {% if shipping_required %}
        <div class="ck-panel" data-step="2">
          <div class="panel-heading">
            <h4 class="panel-title">{{ text_checkout_shipping_address }}</h4>
          </div>
          <div class="panel-collapse collapse" id="collapse-shipping-address">
            <div class="panel-body"></div>
          </div>
        </div>

        {# Step 4: Shipping Method #}
        <div class="ck-panel" data-step="2">
          <div class="panel-heading">
            <h4 class="panel-title">{{ text_checkout_shipping_method }}</h4>
          </div>
          <div class="panel-collapse collapse" id="collapse-shipping-method">
            <div class="panel-body"></div>
          </div>
        </div>
        {% endif %}

        {# Step 5: Payment Method #}
        <div class="ck-panel" data-step="3">
          <div class="panel-heading">
            <h4 class="panel-title">{{ text_checkout_payment_method }}</h4>
          </div>
          <div class="panel-collapse collapse" id="collapse-payment-method">
            <div class="panel-body"></div>
          </div>
        </div>

        {# Step 6: Confirm Order #}
        <div class="ck-panel" data-step="4">
          <div class="panel-heading">
            <h4 class="panel-title">{{ text_checkout_confirm }}</h4>
          </div>
          <div class="panel-collapse collapse" id="collapse-checkout-confirm">
            <div class="panel-body"></div>
          </div>
        </div>

      </div>

      {# Trust strip — V1 Columns #}
      <div class="ck-trust">
        <div class="ck-trust__col">
          <div class="ck-trust__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <div class="ck-trust__label">14 dni vračilo</div>
        </div>
        <div class="ck-trust__col">
          <div class="ck-trust__icon ck-trust__icon--google">
            <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div class="ck-trust__label">4.9 <span class="ck-trust__stars">★★★★★</span></div>
          <div class="ck-trust__sub">153 ocen</div>
        </div>
        <div class="ck-trust__col">
          <div class="ck-trust__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 11.04 11.04 0 0 0 .7 2.81L8.09 9.91a16.07 16.07 0 0 0 6 6l1.27-1.27a11.04 11.04 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3z"/></svg>
          </div>
          <div class="ck-trust__label">Pokliči nas</div>
          <div class="ck-trust__sub"><a href="tel:+38640611233">040 611 233</a></div>
        </div>
      </div>

      {# Back to cart link #}
      <a class="ck-back-link" href="{{ base }}index.php?route=checkout/cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Nazaj na košarico
      </a>
    </div>

    {# Sidebar removed — order summary shown in confirm step #}
  </div>

</div>

{# ── Global utilities (must be available to all script blocks) ── #}
<script type="text/javascript"><!--
function escapeHtml(str) {
  if (!str) return '';
  var div = document.createElement('div');
  div.appendChild(document.createTextNode(str));
  return div.innerHTML;
}
//--></script>

{# ── Checkout UI helpers (consolidated, all fixes applied) ── #}
<script type="text/javascript"><!--
(function($) {
  // Global AJAX timeout — prevent hung requests on slow networks
  $.ajaxSetup({ timeout: 30000 });

  // Rotate payment icons — show 3 at a time on mobile
  $(document).ready(function() {
    if (window.innerWidth >= 768) return;
    var $pay = $('.ck-total-bar__pay');
    if (!$pay.length) return;
    var $icons = $pay.children();
    var total = $icons.length;
    if (total <= 3) return;
    var start = 0;

    function showGroup() {
      $icons.addClass('ck-pay-hidden');
      for (var i = 0; i < 3; i++) {
        $icons.eq((start + i) % total).removeClass('ck-pay-hidden');
      }
    }

    showGroup();

    setInterval(function() {
      start = (start + 3) % total;
      showGroup();
    }, 3000);
  });

  var lockSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-3px;margin-right:6px;"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>';
  var checkSvg = '<svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>';
  var errorMsg = 'Prišlo je do napake. Prosimo, poskusite ponovno.';

  // Scroll to element if off-screen
  window.ckScrollTo = function($el) {
    if (!$el.length) return;
    var elTop = $el.offset().top;
    var viewTop = $(window).scrollTop();
    var viewBottom = viewTop + $(window).height();
    if (elTop < viewTop || elTop > viewBottom - 100) {
      $('html, body').animate({ scrollTop: elTop - 80 }, 300);
    }
  }

  // Global error handler — replaces native alert() with inline message
  window.ckShowAjaxError = function(panelId, xhr) {
    var $panel = $(panelId + ' .panel-body');
    if (!$panel.length) $panel = $('#collapse-payment-address .panel-body');
    $panel.find('.alert-dismissible').remove();
    var $alert = $('<div class="alert alert-danger alert-dismissible">' + errorMsg + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
    $panel.prepend($alert);
    ckScrollTo($alert);
    if (typeof console !== 'undefined') console.error('Checkout error:', xhr ? xhr.statusText : '');
  };

  // Auto-scroll to any new alert injected into checkout panels
  if (typeof MutationObserver !== 'undefined') {
    var observer = new MutationObserver(function(mutations) {
      for (var i = 0; i < mutations.length; i++) {
        for (var j = 0; j < mutations[i].addedNodes.length; j++) {
          var node = mutations[i].addedNodes[j];
          if (node.nodeType === 1 && (node.classList.contains('alert-dismissible') || node.classList.contains('alert'))) {
            ckScrollTo($(node));
          }
        }
      }
    });
    var accordion = document.getElementById('accordion');
    if (accordion) {
      observer.observe(accordion, { childList: true, subtree: true });
    }
  }

  // ── Progress bar ──
  function ckUpdateProgress(stepNum) {
    $('#js-ck-progress .ck-progress__step').each(function() {
      var s = parseInt($(this).attr('data-step'));
      $(this).removeClass('is-active is-done');
      if (s < stepNum) $(this).addClass('is-done');
      if (s === stepNum) $(this).addClass('is-active');
    });
    $('#js-ck-progress .ck-progress__line').each(function(i) {
      $(this).toggleClass('is-done', i < stepNum - 1);
    });
  }

  // ── Address summary (shared by address bar + done summary) ──
  function ckGetAddress() {
    var paymentMode = $('input[name=\'payment_address\']:checked').val();
    if (paymentMode === 'existing') {
      return $('#payment-existing select[name=\'address_id\'] option:selected').text().trim();
    }
    var fn = $('#collapse-payment-address input[name=\'firstname\']').val() || '';
    var ln = $('#collapse-payment-address input[name=\'lastname\']').val() || '';
    var addr = $('#collapse-payment-address input[name=\'address_1\']').val() || '';
    var pc = $('#collapse-payment-address input[name=\'postcode\']').val() || '';
    var city = $('#collapse-payment-address input[name=\'city\']').val() || '';
    var email = $('#collapse-payment-address input[name=\'email\']').val() || '';
    return {
      full: (fn && ln) ? fn + ' ' + ln + ', ' + addr + ', ' + pc + ' ' + city : '',
      short: fn ? fn + ' ' + ln + (email ? ' · ' + email : '') : ''
    };
  }

  function ckInjectAddressBar(panelId) {
    var addr = ckGetAddress();
    if (!addr.full) return;
    var $panel = $(panelId + ' .panel-body');
    $panel.find('.ck-address-bar').remove();
    $panel.prepend(
      '<div class="ck-address-bar"><div class="ck-address-bar__info">'
      + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>'
      + '<span>Dostava na: ' + escapeHtml(addr.full) + '</span>'
      + '</div></div>'
    );
  }

  // ── Pills re-attachment ──
  function ckReattachPills($panelBody) {
    var $pills = $('#js-ck-pills');
    if ($pills.length && !$panelBody.find('#js-ck-pills').length) {
      $panelBody.prepend($pills.detach());
    }
  }

  // ── Loading skeleton ──
  function ckShowSkeleton(panelId) {
    $(panelId + ' .panel-body').html(
      '<div class="ck-skeleton ck-skeleton__line"></div>'
      + '<div class="ck-skeleton ck-skeleton__line ck-skeleton__line--medium"></div>'
      + '<div class="ck-skeleton ck-skeleton__line ck-skeleton__line--short"></div>'
      + '<div class="ck-skeleton ck-skeleton__btn"></div>'
    );
  }

  // ── Done summary ──
  var panelMap = {
    '#collapse-payment-address': { title: 'Tvoji podatki', route: '{% if logged %}checkout/payment_address{% else %}checkout/guest{% endif %}', step: 1 },
    '#collapse-shipping-method': { title: 'Način dostave', route: 'checkout/shipping_method', step: 2 },
    '#collapse-payment-method':  { title: 'Način plačila', route: 'checkout/payment_method', step: 3 },
    '#collapse-checkout-confirm': { title: 'Pregled naročila', route: 'checkout/confirm', step: 4 }
  };

  function ckShowDoneSummary(panelId, title, detail) {
    if (!title || !detail) return;
    $(panelId).closest('.ck-panel').find('.panel-heading').html(
      '<div class="ck-done">'
      + '<div class="ck-done__left">'
      + '<div class="ck-done__check">' + checkSvg + '</div>'
      + '<div class="ck-done__info"><strong>' + escapeHtml(title) + '</strong>' + escapeHtml(detail) + '</div>'
      + '</div>'
      + '<span class="ck-done__edit" data-panel="' + panelId + '">Uredi</span>'
      + '</div>'
    );
  }

  function ckRestorePanelHeading(panelId) {
    var info = panelMap[panelId];
    if (!info) return;
    $(panelId).closest('.ck-panel').find('.panel-heading').html(
      '<h4 class="panel-title"><a href="' + panelId + '" data-toggle="collapse" data-parent="#accordion" class="accordion-toggle">'
      + escapeHtml(info.title) + ' <i class="fa fa-caret-down"></i></a></h4>'
    );
  }

  // ── Confirm proxy button ──
  function ckCreateConfirmProxy() {
    var $btn = $('#button-confirm');
    if (!$btn.length) return;
    $('#ck-confirm-proxy').remove(); // always clean up first
    var total = $('.ck-confirm__totals .ck-confirm__row:last span:last').text().trim();
    $btn.hide();
    $('<button type="button" id="ck-confirm-proxy" class="btn btn-primary">'
      + lockSvg + 'Potrdi naročilo' + (total ? ' — ' + total : '')
      + '</button>'
    ).insertAfter($btn).on('click', function() {
      var $proxy = $(this);
      $proxy.prop('disabled', true).html('<span class="ck-spinner"></span> Obdelujemo naročilo...');
      $btn.trigger('click');
    });
  }

  // ── Event: "Uredi" on completed step ──
  $(document).on('click', '.ck-done__edit', function() {
    var panelId = $(this).data('panel');
    var info = panelMap[panelId];
    if (!info) return;

    // Restore this + all subsequent panel headings
    var panelOrder = ['#collapse-payment-address', '#collapse-shipping-method', '#collapse-payment-method', '#collapse-checkout-confirm'];
    var found = false;
    for (var i = 0; i < panelOrder.length; i++) {
      if (panelOrder[i] === panelId) found = true;
      if (found) ckRestorePanelHeading(panelOrder[i]);
    }

    // Reset progress bar to this step
    ckUpdateProgress(info.step);

    // Reload content
    $.ajax({
      url: 'index.php?route=' + info.route,
      dataType: 'html',
      success: function(html) {
        $(panelId).find('.panel-body').html(html);
        // Re-attach pills for guest form
        if (panelId === '#collapse-payment-address') {
          ckReattachPills($(panelId).find('.panel-body'));
        }
        $(panelId).collapse('show');
      }
    });
  });

  // ── Event: Panel opened ──
  $('#accordion').on('shown.bs.collapse', function(e) {
    var id = e.target.id;

    if (id === 'collapse-payment-address') {
      ckUpdateProgress(1);
      $('#button-guest, #button-register, #button-payment-address').val('Nadaljuj na dostavo');
    }
    if (id === 'collapse-shipping-address') {
      $('#button-guest-shipping, #button-shipping-address').val('Nadaljuj na dostavo');
    }
    if (id === 'collapse-shipping-method') {
      ckUpdateProgress(2);
      ckInjectAddressBar('#collapse-shipping-method');
      $('#button-shipping-method').val('Nadaljuj na plačilo');
      var addr = ckGetAddress();
      if (addr.short) ckShowDoneSummary('#collapse-payment-address', 'Tvoji podatki', addr.short);
    }
    if (id === 'collapse-payment-method') {
      ckUpdateProgress(3);
      $('#button-payment-method').val('Nadaljuj na pregled');
      var $checkedShip = $('#collapse-shipping-method input[name="shipping_method"]:checked');
      if ($checkedShip.length) {
        ckShowDoneSummary('#collapse-shipping-method', 'Način dostave', $checkedShip.closest('label').text().trim());
      }
    }
    if (id === 'collapse-checkout-confirm') {
      ckUpdateProgress(4);
      var $checkedPay = $('#collapse-payment-method input[name="payment_method"]:checked');
      if ($checkedPay.length) {
        ckShowDoneSummary('#collapse-payment-method', 'Način plačila', $checkedPay.closest('label').text().trim());
      }
    }
  });

  // ── AJAX: Show skeleton before loading ──
  $(document).ajaxSend(function(event, xhr, settings) {
    if (!settings.url || settings.url.indexOf('save') !== -1) return;
    var url = settings.url;
    if (url.indexOf('route=checkout/shipping_method') !== -1) ckShowSkeleton('#collapse-shipping-method');
    if (url.indexOf('route=checkout/payment_method') !== -1) ckShowSkeleton('#collapse-payment-method');
    if (url === 'index.php?route=checkout/confirm') ckShowSkeleton('#collapse-checkout-confirm');
  });

  // ── AJAX: Single consolidated ajaxComplete handler ──
  $(document).ajaxComplete(function(event, xhr, settings) {
    if (!settings.url) return;
    var url = settings.url;
    var isSave = url.indexOf('save') !== -1;

    // Shipping method loaded (GET)
    if (!isSave && url.indexOf('route=checkout/shipping_method') !== -1) {
      ckInjectAddressBar('#collapse-shipping-method');
      return;
    }

    // Confirm loaded (GET) — create proxy button
    if (!isSave && url.indexOf('route=checkout/confirm') !== -1) {
      ckCreateConfirmProxy();
      return;
    }

    // Pills re-attachment + button label update (GET)
    if (!isSave && (
      url.indexOf('route=checkout/payment_address') !== -1 ||
      url.indexOf('route=checkout/guest') !== -1 ||
      url.indexOf('route=checkout/register') !== -1
    )) {
      ckReattachPills($('#collapse-payment-address .panel-body'));
      // Update button labels (panel is already open, shown.bs.collapse won't fire)
      $('#button-guest, #button-register, #button-payment-address').val('Nadaljuj na dostavo');
      // Add hint text under phone field
      var $phone = $('#input-payment-telephone');
      if ($phone.length && !$phone.parent().find('.ck-field-hint').length) {
        $phone.after('<span class="ck-field-hint">Kurir vas pokliče ob dostavi</span>');
      }
      // Fix tab order to match visual order (CSS reorders, DOM doesn't)
      // Works for guest, register, AND logged-in new address forms
      $('#input-payment-firstname').attr('tabindex', 1);
      $('#input-payment-lastname').attr('tabindex', 2);
      $('#input-payment-address-1').attr('tabindex', 3);
      $('#input-payment-postcode').attr('tabindex', 4);
      $('#input-payment-city').attr('tabindex', 5);
      $('#input-payment-email').attr('tabindex', 6);
      $('#input-payment-telephone').attr('tabindex', 7);
      $('#input-payment-password').attr('tabindex', 8);
      $('#input-payment-confirm').attr('tabindex', 9);
      // Shipping new address
      $('#input-shipping-firstname').attr('tabindex', 1);
      $('#input-shipping-lastname').attr('tabindex', 2);
      $('#input-shipping-address-1').attr('tabindex', 3);
      $('#input-shipping-postcode').attr('tabindex', 4);
      $('#input-shipping-city').attr('tabindex', 5);
      return;
    }
  });

})(jQuery);
//--></script>

