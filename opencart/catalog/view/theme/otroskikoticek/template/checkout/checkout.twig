{# ── Auto-select default zone after country loads ── #}
<script type="text/javascript"><!--
(function($) {
  var zoneTimer;

  function autoSelectZone(selector) {
    var $zone = $(selector);
    if ($zone.length && (!$zone.val() || $zone.val() === '')) {
      var firstVal = $zone.find('option').not('[value=""]').first().val();
      if (firstVal) $zone.val(firstVal);
    }
  }

  $(document).ajaxComplete(function(event, xhr, settings) {
    if (settings.url && settings.url.indexOf('checkout/checkout/country') !== -1) {
      if (zoneTimer) clearTimeout(zoneTimer);
      zoneTimer = setTimeout(function() {
        autoSelectZone('#collapse-payment-address select[name=\'zone_id\']');
        autoSelectZone('#collapse-shipping-address select[name=\'zone_id\']');
        autoSelectZone('#payment-new select[name=\'zone_id\']');
        autoSelectZone('#shipping-new select[name=\'zone_id\']');
      }, 150);
    }
  });
})(jQuery);
//--></script>

