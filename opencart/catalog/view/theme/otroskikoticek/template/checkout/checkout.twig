{# ── V1 Pills: Guest/Register/Login switching ── #}
<script type="text/javascript"><!--
$(document).ready(function() {
  var $pills = $('#js-ck-pills');
  var $pillGuest = $('#js-pill-guest');
  var $pillRegister = $('#js-pill-register');
  var $pillLogin = $('#js-pill-login');
  var $panelBody = $('#collapse-payment-address .panel-body');

  function setActivePill(mode) {
    $pills.find('.ck-pills__pill').removeClass('is-active');
    $pillLogin.removeClass('is-active is-dimmed');
    if (mode === 'guest') $pillGuest.addClass('is-active');
    if (mode === 'register') { $pillRegister.addClass('is-active'); $pillLogin.addClass('is-dimmed'); }
    if (mode === 'login') $pillLogin.addClass('is-active');
  }

  function loadForm(route, mode) {
    $.ajax({
      url: 'index.php?route=' + route,
      dataType: 'html',
      success: function(html) {
        // Keep pills nav, replace everything after it
        var $pillsHtml = $pills.detach();
        $panelBody.html('').prepend($pillsHtml).append(html);
        setActivePill(mode);
      }
    });
  }

  // Guest pill
  $pills.on('click', '#js-pill-guest', function() {
    loadForm('checkout/guest', 'guest');
  });

  // Register pill
  $pills.on('click', '#js-pill-register', function() {
    loadForm('checkout/register', 'register');
  });

  // Login pill
  $pills.on('click', '#js-pill-login', function() {
    $.ajax({
      url: 'index.php?route=checkout/login',
      dataType: 'html',
      success: function(html) {
        var $pillsHtml = $pills.detach();
        // Extract only the login form (right column) from login.twig
        var $loginHtml = $(html).find('.col-sm-6:last');
        if (!$loginHtml.length) $loginHtml = $(html);
        $panelBody.html('').prepend($pillsHtml).append('<div class="ck-login-form">' + $loginHtml.html() + '</div>');
        setActivePill('login');
        $('#button-login').val('Prijavi se');
      }
    });
  });
});
//--></script>
